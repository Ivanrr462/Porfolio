---
import Badge from "../components/Badge.astro";
import Linkedin from "../components/iconos/Linkedin.astro";
import Github from "../components/iconos/Github.astro";
import SocialPill from "../components/SocialPill.astro";
import Layout from "../layouts/Layout.astro";
import Mail from "../components/iconos/Mail.astro";
import Experiencia from "../components/Experiencia.astro";
import Container from "../components/Container.astro";
import Briefcase from "../components/iconos/briefcase.astro";
import User from "../components/iconos/user.astro";
import CodeIcon from "../components/iconos/CodeIcon.astro";
import Projects from "../components/Projects.astro";
import Goat from "../components/Goat.astro";
---

<Layout title="Portfolio de Ivan - Desarrollador y Programador web">
  <main class="px-4">
    <Container class="py-44 pb-32">
      <div class="flex flex-col md:flex-row items-center gap-10">
        <img
          class="rounded-full w-32 h-32 md:w-40 md:h-40 lg:w-44 lg:h-44"
          src="/images/me.png"
          alt="foto"
        />
        <div class="max-w-3xl">
          <div class="flex flex-col gap-4">
            <div>
              <div class="flex flex-col sm:flex-row sm:items-center sm:gap-4 gap-2">
                <h1 class="text-white text-3xl md:text-4xl lg:text-5xl font-bold">
                  Hey, I'm Iván Ríos
                </h1>
                <Badge>Open to Work</Badge>
              </div>
              <p class="mt-3 text-grey text-lg lg:text-xl opacity-60 text-pretty max-w-[700px]">
                Full Stack Developer who loves creating cool stuff and solving real problems.
              </p>
            </div>
          </div>
        </div>
      </div>

      <section class="mt-20 max-w-3xl" id="about">
        <h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
          <User class="size-7" />
          About
        </h2>
        <p class="text-grey opacity-60 text-pretty">
          I have experience building modern web applications and a strong foundation in Networked Computer Systems Administration. I enjoy exploring new technologies, creating efficient solutions, and continuously improving my workflow.
        </p>
      </section>

      <nav class="flex gap-4 mt-8 flex-wrap">
        <SocialPill
          href="https://github.com/Ivanrr462"
          class="bg-[#24292e] hover:bg-[#24292e]/90 hover:ring-[#24292e]"
        >
          <Github class="size-4 md:size-6" />
          GitHub
        </SocialPill>
        <SocialPill
          href="https://www.linkedin.com/in/ivanriosdev"
          class="bg-[#0A66C2] hover:bg-[#0A66C2]/90 hover:ring-[#0A66C2]"
        >
          <Linkedin class="size-4 md:size-6" />
          LinkedIn
        </SocialPill>
      </nav>
    </Container>

    <Container id="experiencia">
      <h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
        <Briefcase class="size-7" />
        Experiencia laboral
      </h2>
      <Experiencia />
    </Container>

    <Container id="proyectos">
      <h2 class="text-3xl font-semibold mb-6 flex gap-x-3 items-center">
        <CodeIcon class="size-7" />
        Proyectos
      </h2>
      <Projects />
    </Container>

    <Goat />
  </main>
</Layout>
