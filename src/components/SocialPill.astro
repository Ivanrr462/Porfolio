---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class={`${className} inline-flex items-center gap-2 px-4 py-2 rounded-md text-sm font-medium
    text-white shadow-md transition-all duration-300 ease-out
    hover:shadow-lg hover:scale-105 hover:-translate-y-0.5
    focus-visible:outline-none focus-visible:ring-2
    active:scale-95 overflow-hidden relative group whitespace-nowrap`}
>
  <!-- Shine effect -->
  <span
    class="absolute right-0 -mt-12 h-32 w-8 translate-x-12 rotate-12 bg-white opacity-10
      transition-all duration-700 ease-out group-hover:-translate-x-40 pointer-events-none"
  ></span>

  <slot />
</a>
