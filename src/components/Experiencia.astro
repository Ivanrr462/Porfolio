---
import ExperienciaItem from "./ExperienciaItem.astro";

const EXPERIENCIA = [
  {
    date: "February – May 2026",
    title: "Junior Software Developer",
    empresa: "Tsunoa Games",
    empresaUrl: "https://tsunoagames.com/",
    description:
      "Built and maintained WordPress sites, developing and reviewing automations with AutomatorWP to optimize workflows. Managed team tasks using GitLab Issue Boards.",
  },
  {
    date: "March – June 2025",
    title: "Junior Web Developer",
    empresa: "Agencia Digital de Andalucía",
    empresaUrl: "https://www.juntadeandalucia.es/organismos/ada.html",
    description:
      "Migrated databases, automated critical tasks using AI-assisted PowerShell scripting, and managed projects with Kanban methodology.",
  },
  {
    date: "March – June 2024",
    title: "IT Technician",
    empresa: "Emasa",
    empresaUrl: "https://www.emasa.es/",
    description:
      "Managed critical infrastructure by automating deployments with AWX/Ansible and administering servers via ManageEngine. Maintained key systems including SQL Server, DNS, and BitLocker.",
  },
];
---

<ol class="relative border-s border-gray-300 dark:border-gray-700 ml-3">
  {
    EXPERIENCIA.map((experience) => (
      <li class="mb-10 ms-4">
        <ExperienciaItem {...experience} />
      </li>
    ))
  }
</ol>
