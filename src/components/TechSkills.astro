      </span>

      <span class="skill-badge bg-green-600/10 border-green-600/30 text-green-700 dark:text-green-400">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.193 9.555c-1.264-5.58-4.252-7.414-4.573-8.115-.28-.394-.53-.954-.735-1.44-.036.495-.055.685-.523 1.184-.723.566-4.438 3.682-4.74 10.02-.282 5.912 4.27 9.435 4.888 9.884l.07.05A73.49 73.49 0 0111.91 24h.481c.114-1.032.17-2.066.17-3.1 0-.524-.039-1.04-.116-1.553zm-3.2 5.81c-.169.087-.349.164-.527.23a1.04 1.04 0 01-.463.043c-.13-.023-.256-.07-.373-.138a1.12 1.12 0 01-.29-.23 1.042 1.042 0 01-.19-.319 1.1 1.1 0 01-.061-.373c0-.14.021-.276.065-.405a1.02 1.02 0 01.189-.34c.081-.098.18-.182.289-.248.11-.066.228-.113.354-.14l.066-.013c.152-.03.306-.045.46-.045.16 0 .318.017.47.05a1.22 1.22 0 01.388.145c.11.065.21.147.296.242.086.096.152.205.199.323a1.1 1.1 0 01.07.395c0 .142-.022.28-.067.41a1.03 1.03 0 01-.196.338 1.078 1.078 0 01-.319.23zm.36-2.047a2.31 2.31 0 00-.585-.149 3.3 3.3 0 00-.6-.038 3.12 3.12 0 00-.58.059 2.35 2.35 0 00-.557.184 2.155 2.155 0 00-.456.307 2.04 2.04 0 00-.34.432 2.07 2.07 0 00-.21.543 2.5 2.5 0 00-.069.6c0 .22.025.433.076.638.05.204.128.393.232.563.105.17.236.32.392.447.156.126.337.227.538.3.2.072.42.108.65.108.238 0 .46-.038.664-.115.204-.077.384-.184.537-.32.153-.137.273-.3.358-.488.086-.188.13-.394.13-.615 0-.22-.04-.424-.12-.614a1.624 1.624 0 00-.34-.494 1.622 1.622 0 00-.524-.33z"/></svg>
