---
import Laravel from "./iconos/Laravel.astro";
import Docker from "./iconos/Docker.astro";
import JavaScript from "./iconos/JavaScript.astro";
import Php from "./iconos/php.astro";

// Icon inline SVGs as strings are rendered via set:html below
---

<div class="flex flex-col gap-10">

  <!-- Frontend Development -->
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3 flex items-center gap-2">
      <span>🎨</span> Frontend Development
    </p>
    <div class="flex flex-wrap gap-2">

      <span class="skill-badge bg-sky-500/10 border-sky-500/30 text-sky-700 dark:text-sky-300">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M14.23 12.004a2.236 2.236 0 0 1-2.235 2.236 2.236 2.236 0 0 1-2.236-2.236 2.236 2.236 0 0 1 2.235-2.236 2.236 2.236 0 0 1 2.236 2.236zm2.648-10.69c-1.346 0-3.107.96-4.888 2.622-1.78-1.653-3.542-2.602-4.887-2.602-.41 0-.783.093-1.106.278-1.375.793-1.683 3.264-.973 6.365C1.98 8.917 0 10.42 0 12.004c0 1.59 1.99 3.097 5.043 4.03-.704 3.113-.39 5.588.988 6.38.32.187.69.275 1.102.275 1.345 0 3.107-.96 4.888-2.624 1.78 1.654 3.542 2.603 4.887 2.603.41 0 .783-.09 1.106-.275 1.374-.792 1.683-3.263.973-6.365C22.02 15.096 24 13.59 24 12.004c0-1.59-1.99-3.097-5.043-4.032.704-3.11.39-5.587-.988-6.38a2.167 2.167 0 0 0-1.096-.278zm-.66 11.34a5.432 5.432 0 0 1-.926-.062 8.374 8.374 0 0 1-.498 1.09c.47.15.947.257 1.42.294-.288.787-.706 1.348-1.126 1.348-.123 0-.25-.034-.382-.1-1.012-.55-2.01-2.32-2.646-4.776.637-2.455 1.634-4.223 2.647-4.772.132-.067.26-.1.383-.1.42 0 .838.562 1.126 1.349a7.91 7.91 0 0 1-1.42.293 8.33 8.33 0 0 1 .497 1.09c.31-.04.625-.06.927-.06.3 0 .616.02.926.06a8.374 8.374 0 0 1 .498-1.09 7.904 7.904 0 0 1-1.42-.294c.288-.787.706-1.348 1.126-1.348.123 0 .25.034.382.1 1.012.55 2.01 2.32 2.646 4.776-.636 2.456-1.634 4.224-2.647 4.773-.132.066-.26.1-.383.1-.42 0-.838-.562-1.126-1.349a7.93 7.93 0 0 1 1.42-.293 8.292 8.292 0 0 1-.497-1.09z"/></svg>
        React
      </span>

      <span class="skill-badge bg-cyan-500/10 border-cyan-500/30 text-cyan-700 dark:text-cyan-300">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M12.001 4.8c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624C13.666 10.618 15.027 12 18.001 12c3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C16.337 6.182 14.976 4.8 12.001 4.8zm-6 7.2c-3.2 0-5.2 1.6-6 4.8 1.2-1.6 2.6-2.2 4.2-1.8.913.228 1.565.89 2.288 1.624 1.177 1.194 2.538 2.576 5.512 2.576 3.2 0 5.2-1.6 6-4.8-1.2 1.6-2.6 2.2-4.2 1.8-.913-.228-1.565-.89-2.288-1.624C10.337 13.382 8.976 12 6.001 12z"/></svg>
