      </span>

      <span class="skill-badge bg-orange-500/10 border-orange-500/30 text-orange-700 dark:text-orange-300">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M16.074 16.86C15.354 17.476 13.917 17.9 12.262 17.9c-2.106 0-3.85-.666-4.265-1.562-.164-.35-.052-.967.263-1.756l.03-.077c.38-.984 1.279-2.07 2.484-2.948 1.205-.878 2.592-1.394 3.867-1.394.37 0 .727.04 1.063.12.195.047.378.107.549.18.35 2.302-.053 4.282-1.177 5.397zm1.282-7.62a7.27 7.27 0 00-2.183-.305c-1.748 0-3.627.673-5.145 1.844-1.518 1.17-2.704 2.746-3.177 4.257-.45 1.434-.219 2.677.647 3.463C8.418 19.29 10.257 20 12.262 20c2.006 0 3.846-.71 5.096-1.952a6.48 6.48 0 001.478-2.456 6.524 6.524 0 00.293-2.584 7.154 7.154 0 00-.485-2.14 7.198 7.198 0 00-1.288-1.628zM12 2L4.5 19.5l1.5.5L12 6.5l6 13.5 1.5-.5L12 2z"/></svg>
        Astro
      </span>

    </div>
  </div>

  <!-- Backend Development -->
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3 flex items-center gap-2">
      <span>🖥️</span> Backend Development
    </p>
    <div class="flex flex-wrap gap-2">

      <span class="skill-badge bg-violet-500/10 border-violet-500/30 text-violet-700 dark:text-violet-300">
        <Php class="size-4 shrink-0" />
        PHP
      </span>

      <span class="skill-badge bg-red-500/10 border-red-500/30 text-red-700 dark:text-red-300">
        <Laravel class="size-4 shrink-0" />
        Laravel
      </span>

      <span class="skill-badge bg-amber-500/10 border-amber-500/30 text-amber-700 dark:text-amber-300">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M8.851 18.56s-.917 1.403.589 1.409c1.316.006 2.018-.755 2.018-.755s2.519 1.454 4.195.228c0 0 .94 1.527 1.765 1.527c.773 0 2.128-.842 2.128-1.756c0 0 .924.3 1.607-.207c.683-.508.683-1.506.683-1.506s.996-1.01.768-1.993c-.228-.983-.915-1.09-.915-1.09s.61-1.002.61-2.198c0-1.195-.55-2.083-1.367-1.982c0 0 .267-1.378-.78-1.378c-1.047 0-1.334 1.112-1.334 1.112s-.695-.666-1.77-.415c0 0-.303-1.028-1.286-1.028c-.983 0-1.286.975-1.286.975s-.898-.503-1.698.025c-.799.528-.9 1.556-.9 1.556s-1.21-.22-1.74.655c-.531.876-.154 2.088-.154 2.088s-.799.411-.8 1.508c-.001 1.096.702 1.91.702 1.91s-.756.734-.516 1.673c.241.94 1.189 1.096 1.189 1.096s-.024.745.68.745c.705 0 .705-.745.705-.745zM19.116 7.861c.681-.682.969-1.457.647-1.73c-.322-.272-1.095.077-1.776.76c-.681.682-.969 1.457-.647 1.73c.322.272 1.095-.077 1.776-.76zM4.786 7.367c-.51-.633-.693-1.358-.406-1.624c.288-.266 1.01.046 1.52.679c.51.633.693 1.358.406 1.624c-.288.266-1.01-.046-1.52-.679zM12 2C6.477 2 2 6.477 2 12s4.477 10 10 10S22 17.523 22 12S17.523 2 12 2z"/></svg>
