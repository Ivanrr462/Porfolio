      </span>

    </div>
  </div>

  <!-- DevOps & CLI Tools -->
  <div>
    <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 dark:text-gray-500 mb-3 flex items-center gap-2">
      <span>⚙️</span> DevOps & CLI Tools
    </p>
    <div class="flex flex-wrap gap-2">

      <span class="skill-badge bg-blue-600/10 border-blue-600/30 text-blue-700 dark:text-blue-300">
        <Docker class="size-4 shrink-0" />
        Docker
      </span>

      <span class="skill-badge bg-orange-600/10 border-orange-600/30 text-orange-700 dark:text-orange-300">
        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.546 10.93L13.067.452c-.604-.603-1.582-.603-2.188 0L8.708 2.627l2.76 2.76c.645-.215 1.379-.07 1.889.441.516.515.658 1.258.438 1.9l2.658 2.66c.645-.223 1.387-.078 1.9.435.721.72.721 1.884 0 2.604-.719.719-1.881.719-2.6 0-.539-.541-.674-1.337-.404-1.996L12.86 8.955v6.525c.176.086.342.203.488.348.713.721.713 1.883 0 2.6-.719.721-1.889.721-2.609 0-.719-.719-.719-1.879 0-2.598.182-.18.387-.316.605-.406V8.835c-.217-.091-.424-.222-.608-.406-.545-.545-.676-1.342-.396-2.009L7.636 3.7.45 10.881c-.6.605-.6 1.584 0 2.189l10.48 10.477c.604.604 1.582.604 2.186 0l10.43-10.43c.605-.603.605-1.582 0-2.187"/></svg>
