        <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M19.58 12.27c-.02-.01-1.64-.98-1.64-.98l-5.94-3.53V4.53c0-.42-.23-.82-.59-1.03-.37-.21-.82-.21-1.18 0L4.41 6.94C4.05 7.15 3.82 7.55 3.82 7.97v6.77c0 .42.23.82.59 1.03l5.82 3.36c.18.1.38.16.59.16.2 0 .4-.05.59-.16l3.68-2.12 1.64.97c.19.11.4.17.6.17.21 0 .42-.06.6-.17l1.65-.95c.37-.22.6-.61.6-1.04v-1.93c0-.43-.23-.82-.6-1.03zM5.45 8.4l4.77-2.76v2.76L5.45 11.1V8.4zm4.77 8.22-4.77-2.76v-2.7l4.77 2.76v2.7zm.59-4.1-4.36-2.52 4.36-2.52 4.36 2.52-4.36 2.52zm5.36 3.11-1.04.6-1.04-.62v-2.7l1.04.62 1.04-.6v2.7z"/></svg>
