---
interface Props {
  title: string;
  description: string;
  link?: string;
  empresa: string;
  empresaUrl?: string;
  date: string;
}

const { title, description, link, date, empresa, empresaUrl } = Astro.props;
---

<div
  class="absolute w-3 h-3 bg-blue-400 rounded-full mt-1.5 -start-1.5
  border-2 border-gray-900"
>
</div>

<time class="mb-1 text-xs font-medium leading-none tracking-wide uppercase
  text-blue-600/70 dark:text-blue-300/70">
  {date}
</time>

<h3 class="text-lg font-semibold mt-1 text-gray-900 dark:text-white">
  {title}
</h3>

{
  empresaUrl ? (
    <a
      href={empresaUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-sm transition-colors mt-0.5 group
        text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
    >
      {empresa}
      <svg
        class="w-3 h-3 opacity-60 group-hover:opacity-100 transition-opacity"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>
  ) : (
    <span class="text-sm mt-0.5 block text-blue-600/80 dark:text-blue-400/80">{empresa}</span>
  )
}

<p class="mt-3 mb-2 text-base font-normal text-pretty leading-relaxed
  text-gray-600 dark:text-gray-300">
  {description}
</p>